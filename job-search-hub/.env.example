# Rename this file to .env and fill in your values
# Never commit .env to Git

# Server environment (required)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=http://localhost:3001/auth/callback
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# Optional: Claude for Elite/admin extraction (and Pro initial sync if USE_SONNET_FOR_INITIAL_SYNC=true)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Pro: set true to use Claude on wide/initial sync only. Set false to disable Claude for everyone.
USE_SONNET_FOR_INITIAL_SYNC=
FRONTEND_URL=http://localhost:5173
PORT=3001

# Server environment (optional)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CORS_ALLOWED_ORIGINS=http://localhost:5173
EXTERNAL_API_TIMEOUT_MS=12000
RETRY_ATTEMPTS=2
OPENAI_COOLDOWN_HOURS=6
# First Gmail sync and "Sync last month" use newer_than:Nd (default 30 ≈ 1 month)
INITIAL_SYNC_LOOKBACK_DAYS=30
DAILY_SYNC_LOOKBACK_DAYS=1
GMAIL_SYNC_MAX_RESULTS_PER_PAGE=100
INITIAL_SYNC_MAX_MESSAGES=1000
INCREMENTAL_SYNC_MAX_MESSAGES=500
# Default 9:00 PM once per day (server local time). Set SYNC_CRON_TIMEZONE=America/New_York for a fixed zone.
SYNC_CRON=0 21 * * *
SYNC_CRON_TIMEZONE=
SYNC_PROCESSING_CONCURRENCY=3
# Manual "Sync jobs" per user per hour (by plan)
RATE_LIMIT_SYNC_FREE=3
RATE_LIMIT_SYNC_PRO=12
RATE_LIMIT_SYNC_ELITE=30
RATE_LIMIT_SYNC_ADMIN=60
MCP_AUTH_TOKEN=
MCP_AUDIT_LOG_ENABLED=true
MCP_ALLOWED_TOOLS=
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX_REQUESTS=120
NOTIFY_EMAIL_WEBHOOK_URL=
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_WHATSAPP_WEBHOOK_URL=

# Email (SMTP for sending verification, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@job-search-hub.com
SMTP_FROM_NAME=Job Search Hub
OTP_SEND_MODE=console

# Session and CSRF protection (required for OAuth flow)
SESSION_SECRET=your-strong-random-session-secret-here

# JWT signing secret (required for auth tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=your-32-byte-hex-encoded-secret-here

# Token encryption key for OAuth tokens (recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to store tokens unencrypted (dev only!)
TOKEN_ENCRYPTION_KEY=

# Logging level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Stripe billing (required for paid tiers)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# Environment
ENVIRONMENT=development

# Client build-time environment
VITE_BACKEND_URL=http://localhost:3001