# Rename this file to .env and fill in your values
# Never commit .env to Git

# Server environment
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=https://YOUR-RAILWAY-APP.up.railway.app/auth/callback
ANTHROPIC_API_KEY=your_anthropic_api_key_here
FRONTEND_URL=https://claude.ai
PORT=3001
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CORS_ALLOWED_ORIGINS=http://localhost:5173
EXTERNAL_API_TIMEOUT_MS=12000
RETRY_ATTEMPTS=2

# Client environment (when frontend is scaffolded)
VITE_BACKEND_URL=http://localhost:3001