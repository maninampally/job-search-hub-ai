# Rename this file to .env and fill in your values
# Never commit .env to Git

# Server environment (required)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=https://YOUR-RAILWAY-APP.up.railway.app/auth/callback
ANTHROPIC_API_KEY=your_anthropic_api_key_here
FRONTEND_URL=http://localhost:5173
PORT=3001

# Server environment (optional)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CORS_ALLOWED_ORIGINS=http://localhost:5173
EXTERNAL_API_TIMEOUT_MS=12000
RETRY_ATTEMPTS=2
INITIAL_SYNC_LOOKBACK_DAYS=180
DAILY_SYNC_LOOKBACK_DAYS=1
GMAIL_SYNC_MAX_RESULTS_PER_PAGE=100
INITIAL_SYNC_MAX_MESSAGES=1000
SYNC_CRON=0 9 * * *
SYNC_PROCESSING_CONCURRENCY=3
MCP_AUTH_TOKEN=
MCP_AUDIT_LOG_ENABLED=true
MCP_ALLOWED_TOOLS=
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX_REQUESTS=120
NOTIFY_EMAIL_WEBHOOK_URL=
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_WHATSAPP_WEBHOOK_URL=

# Client build-time environment
VITE_BACKEND_URL=http://localhost:3001