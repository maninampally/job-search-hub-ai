{
  "name": "job-search-hub",
  "version": "1.0.0",
  "description": "Job Search Hub monorepo with organized client/server/docs layout",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "start:server": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm --prefix client run dev",
    "db:schema": "echo Run docs/database/schema.sql in your Supabase SQL editor"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "googleapis": "^140.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
